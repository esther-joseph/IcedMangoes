# MongoDB
MONGO_HOST=mongodb
MONGO_PORT=27017
MONGO_INITDB_DATABASE=artist_store_db
MONGO_USERNAME=root
MONGO_PASSWORD=secret

# Prisma (when USE_SQLITE=1)
DATABASE_URL="file:./db.sqlite3"

# Stripe (optional; without it, checkout creates order without payment)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Fulfillment providers (optional; configure in Business page or here)
SHIPPO_API_TOKEN=
EASYPOST_API_KEY=
PRINTFUL_API_KEY=
PRINTIFY_API_KEY=
GELATO_API_KEY=

# Supabase Storage (optional; for production - Render has ephemeral filesystem)
# When set, artwork images are stored in Supabase instead of local media/
# Create bucket "media" in Supabase Storage, generate S3 credentials in Storage settings
SUPABASE_STORAGE_BUCKET=media
SUPABASE_S3_ENDPOINT=https://<project-ref>.supabase.co/storage/v1/s3
SUPABASE_S3_REGION=us-east-1
SUPABASE_S3_ACCESS_KEY_ID=
SUPABASE_S3_SECRET_ACCESS_KEY=
# For public bucket (recommended for storefront images):
SUPABASE_STORAGE_PUBLIC_BASE_URL=https://<project-ref>.supabase.co/storage/v1/object/public/media
# Set MEDIA_PRIVATE=true for signed URLs (private bucket)

# Django (optional; defaults shown)
DJANGO_SECRET_KEY=dev-secret-change-in-production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
